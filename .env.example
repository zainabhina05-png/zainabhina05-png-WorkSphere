# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://username:password@your-pooler-endpoint.neon.tech/neondb?sslmode=require"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key"
CLERK_SECRET_KEY="sk_test_your_secret_key"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# AI (Groq)
GROQ_API_KEY="gsk_your_groq_api_key"

# Admin Configuration
ADMIN_EMAILS="admin@worksphere.com,your-email@example.com"

# Webhook Secrets
WEBHOOK_SECRET="whsec_your_clerk_webhook_secret"
SVIX_TOKEN="your_svix_api_token"
WORKER_SECRET="your_internal_worker_secret"

